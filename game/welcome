print ("Hello, welcome to the game")
class Player:
    def __init__(self, name):
        self.name = name
        self.health = 100
        self.strength = 5
        self.intellect = 5
        self.gold = 100
        self.reputation = 0

    def train_strength(self):
        self.strength += 1
        print(f"{self.name} trained and increased strength to {self.strength}!")

    def show_stats(self):
        print(f"{self.name} | HP: {self.health} | STR: {self.strength} | INT: {self.intellect} | Gold: {self.gold}")
